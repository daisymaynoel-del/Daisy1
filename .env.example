# ─── EASTEND Social Media Growth Agent — Environment Variables ───────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                      # development | production
SECRET_KEY=change-me-to-a-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Instagram Graph API ───────────────────────────────────────────────────────
# Get these from developers.facebook.com → your app → Instagram Basic Display
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=                  # Long-lived page access token
INSTAGRAM_BUSINESS_ACCOUNT_ID=          # Your IG Business Account ID
FACEBOOK_PAGE_ID=                        # Connected Facebook Page ID

# ── TikTok Content Posting API ────────────────────────────────────────────────
# Get these from developers.tiktok.com → your app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=                          # Your TikTok Creator Open ID

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                       # From console.anthropic.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./eastend.db      # SQLite for dev; swap to postgres:// for prod

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
THUMBNAIL_DIR=thumbnails
MAX_UPLOAD_SIZE_MB=500

# ── Scheduling ────────────────────────────────────────────────────────────────
# Posting times in 24h format (comma-separated), London timezone
POST_TIMES_INSTAGRAM=12:00,17:00,19:30
POST_TIMES_TIKTOK=12:00,17:00,19:30
TIMEZONE=Europe/London

# ── Agent Behaviour ───────────────────────────────────────────────────────────
APPROVAL_REQUIRED=true                   # false = full autonomy (set after 7 days)
UNDERPERFORM_THRESHOLD=0.5               # Flag post if predicted <50% of avg
METRICS_COLLECTION_INTERVALS=1h,6h,24h,72h,7d

# ── Demo Mode (no real API calls) ─────────────────────────────────────────────
DEMO_MODE=true                           # Set to false when real credentials are ready
